@model ControleFinanceiroMvc.Models.ViewModels.CategoriaViewModel

@{
    ViewData["Title"] = "Editar categoria";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h2 mb-1">Editar categoria</h1>
                <p class="text-muted mb-0">Atualize os dados da categoria.</p>
            </div>
            <a class="btn btn-outline-secondary" asp-action="Index">Voltar</a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Editar" method="post" novalidate>
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Nome" class="form-label"></label>
                        <input asp-for="Nome" class="form-control" />
                        <span asp-validation-for="Nome" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Tipo" class="form-label"></label>
                        <select asp-for="Tipo" class="form-select">
                            <option value="">Selecione</option>
                            <option value="Receita">Receita</option>
                            <option value="Despesa">Despesa</option>
                        </select>
                        <span asp-validation-for="Tipo" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Salvar alterações</button>
                        <a class="btn btn-light border" asp-action="Index">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
